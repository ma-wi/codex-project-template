# Template-state fail-closed defaults for focused gates.
#
# In a pristine template, run .ai/tools/verify.sh; it delegates to
# verify-template.sh before reading these empty commands. After bootstrap,
# .ai/tools/bootstrap.py replaces this file with project-specific, strict,
# versioned commands. Commit the generated result. Put machine-local overrides in
# the ignored .ai/config/project.env.
SETUP_CMD=''
FORMAT_CHECK_CMD=''
FORMAT_APPLY_CMD=''
LINT_CMD=''
TEST_CMD=''
SECURITY_CMD=''
DEPENDENCY_SCAN_CMD=''
BUILD_CMD=''

REQUIRE_SETUP=1
REQUIRE_FORMAT_CHECK=1
REQUIRE_LINT=1
REQUIRE_TEST=1
REQUIRE_SECURITY=1
REQUIRE_DEPENDENCY_POLICY=1
REQUIRE_DEPENDENCY_SCANNERS=1
REQUIRE_BUILD=1
