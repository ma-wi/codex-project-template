# Copy to .ai/config/project.env for local overrides.
# Commands are executed from the repository root through: bash -lc "$COMMAND"
# Committed defaults live in project.defaults.env. Values here override them.

# FORMAT_CHECK_CMD=''
# FORMAT_APPLY_CMD=''
# LINT_CMD=''
# TEST_CMD=''
# SECURITY_CMD=''
# DEPENDENCY_SCAN_CMD=''
# DEPENDENCY_REPUTATION_CMD='' # e.g. an approved Socket/Snyk/Mend command
# BUILD_CMD=''

# Set to 1 when a gate must fail if no command can be configured or detected.
REQUIRE_FORMAT_CHECK=0
REQUIRE_LINT=0
REQUIRE_TEST=0
REQUIRE_SECURITY=0
REQUIRE_DEPENDENCY_POLICY=1
REQUIRE_DEPENDENCY_SCANNERS=0
REQUIRE_SETUP=0

# Package policy controls.
DEPENDENCY_ALLOWLIST_MODE=0
REQUIRE_LOCKFILES=1
REJECT_FLOATING_VERSIONS=1
REQUIRE_BUILD=0
# SETUP_CMD=''
