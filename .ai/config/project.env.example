# Copy to .ai/config/project.env for local overrides.
# Commands are executed from the repository root through: bash -lc "$COMMAND".
# Focused gate scripts use these overrides; full verify.sh deliberately ignores them.

# FORMAT_CHECK_CMD=''
# FORMAT_APPLY_CMD=''
# LINT_CMD=''
# TEST_CMD=''
# SECURITY_CMD=''
# DEPENDENCY_SCAN_CMD=''
# DEPENDENCY_REPUTATION_CMD='' # e.g. an approved Socket/Snyk/Mend command
# BUILD_CMD=''

# Requiredness is committed policy and cannot be weakened here. Change mandatory
# gates only through a reviewed edit to project.defaults.env and the quality policy.

# Package policy controls.
DEPENDENCY_ALLOWLIST_MODE=0
# SETUP_CMD=''
