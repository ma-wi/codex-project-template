# Local agent and verification overrides. The generated
# .ai/config/project.defaults.env is committed and is the CI source of truth.
.ai/config/project.env

# IntelliJ IDEA: keep personal/local state out of Git.
.idea/*
.idea/vcs.xml
.idea/workspace.xml
.idea/shelf/

# Common secrets and local environments
.env
.env.*
!.env.example
.venv/
venv/

# Python caches
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Build, test, and dependency output
build/
dist/
target/
coverage/
node_modules/
